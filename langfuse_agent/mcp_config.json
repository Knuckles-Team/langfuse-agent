{
  "mcpServers": {
    "langfuse": {
      "command": "uv",
      "args": [
        "run",
        "langfuse-mcp"
      ],
      "env": {
        "LANGFUSE_BASE_URL": "${LANGFUSE_BASE_URL:-http://localhost:3000}",
        "LANGFUSE_PUBLIC_KEY": "${LANGFUSE_PUBLIC_KEY}",
        "LANGFUSE_SECRET_KEY": "${LANGFUSE_SECRET_KEY}",
        "MCP_TOOL_MODE": "${MCP_TOOL_MODE:-condensed}",
        "LANGFUSE_OBSERVABILITYTOOL": "${LANGFUSE_OBSERVABILITYTOOL:-True}",
        "LANGFUSE_DATASETSTOOL": "${LANGFUSE_DATASETSTOOL:-True}",
        "LANGFUSE_PROMPTS_MODELSTOOL": "${LANGFUSE_PROMPTS_MODELSTOOL:-True}",
        "LANGFUSE_MANAGEMENTTOOL": "${LANGFUSE_MANAGEMENTTOOL:-True}",
        "AGENT_DESCRIPTION": "<YOUR_AGENT_DESCRIPTION>",
        "AGENT_SYSTEM_PROMPT": "<YOUR_AGENT_SYSTEM_PROMPT>",
        "DEFAULT_AGENT_NAME": "<YOUR_DEFAULT_AGENT_NAME>"
      }
    }
  }
}
